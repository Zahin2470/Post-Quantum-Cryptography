    "        \n",
    "        # Box plot\n",
    "        data_to_plot = [classical_traffic[feature].dropna(), pqc_traffic[feature].dropna()]\n",
    "        bp = ax.boxplot(data_to_plot, labels=['Classical', 'PQC'], patch_artist=True)\n",
    "        \n",
