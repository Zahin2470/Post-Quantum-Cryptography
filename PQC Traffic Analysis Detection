    "# Split data before resampling\n",
    "if y is not None:\n",
    "    X_train, X_test, y_train, y_test = train_test_split(\n",
    "        X, y, test_size=0.2, random_state=RANDOM_SEED, stratify=y\n",
    "    )\n",
    "    \n",
    "    print(f\"Training set: {X_train.shape}\")\n",
    "    print(f\"Test set: {X_test.shape}\")\n",
    "    print(f\"\\nOriginal class distribution in training:\")\n",
    "    print(pd.Series(y_train).value_counts())\n",
    "    \n",
    "    # Normalize features\n",
    "    scaler = StandardScaler()\n",
    "    X_train_scaled = scaler.fit_transform(X_train)\n",
    "    X_test_scaled = scaler.transform(X_test)\n",
    "    \n",
    "    # Convert back to DataFrame for easier handling\n",
    "    X_train_scaled = pd.DataFrame(X_train_scaled, columns=X.columns)\n",
    "    X_test_scaled = pd.DataFrame(X_test_scaled, columns=X.columns)\n",
    "    \n",
    "    # ==================== SMOTE Resampling ====================\n",
    "    print(\"\\n🔄 Applying SMOTE resampling...\")\n",
    "    smote = SMOTE(random_state=RANDOM_SEED)\n",
    "    X_train_smote, y_train_smote = smote.fit_resample(X_train_scaled, y_train)\n",
    "    \n",
    "    print(f\"After SMOTE: {X_train_smote.shape}\")\n",
    "    print(f\"Class distribution after SMOTE:\")\n",
    "    print(pd.Series(y_train_smote).value_counts())\n",
    "    \n",
    "    # ==================== DP-CTGAN Resampling (Optional) ====================\n",
    "    print(\"\\n🤖 Attempting DP-CTGAN resampling...\")\n",
    "    try:\n",
    "        # Combine features and labels for CTGAN\n",
    "        train_data_ctgan = X_train_scaled.copy()\n",
    "        train_data_ctgan['label'] = y_train\n",
    "        \n",
    "        # Initialize CTGAN\n",
    "        ctgan = CTGAN(\n",
    "            epochs=15,  # Reduce for speed in demo\n",
    "            batch_size=500,\n",
    "            verbose=True\n",
    "        )\n",
    "        \n",
    "        # Fit CTGAN\n",
    "        print(\"Training CTGAN model...\")\n",
    "        ctgan.fit(train_data_ctgan, discrete_columns=['label'])\n",
    "        \n",
    "        # Calculate how many synthetic samples needed for perfect balance\n",
    "        class_counts = pd.Series(y_train).value_counts()\n",
    "        majority_class = class_counts.idxmax()\n",
    "        minority_class = class_counts.idxmin()\n",
    "        majority_count = class_counts.max()\n",
    "        minority_count = class_counts.min()\n",
    "        \n",
    "        # We need to generate enough samples to balance the minority class\n",
    "        n_synthetic = majority_count - minority_count\n",
    "        \n",
    "        print(f\"Majority class ({majority_class}): {majority_count} samples\")\n",
    "        print(f\"Minority class ({minority_class}): {minority_count} samples\")\n",
    "        print(f\"Generating {n_synthetic} synthetic samples for minority class...\")\n",
    "        \n",
    "        # Generate synthetic samples\n",
    "        # Generate more than needed to ensure we get enough of the minority class\n",
    "        synthetic_data = ctgan.sample(n_synthetic * 2)  # Generate 2x to ensure enough\n",
    "        \n",
    "        # Filter synthetic data for minority class only\n",
    "        synthetic_minority = synthetic_data[synthetic_data['label'] == minority_class]\n",
    "        \n",
    "        # Take only the number we need\n",
    "        synthetic_minority = synthetic_minority.head(n_synthetic)\n",
    "        \n",
    "        print(f\"Generated {len(synthetic_minority)} synthetic minority class samples\")\n",
    "        \n",
    "        # Combine with original data\n",
    "        X_train_ctgan = pd.concat([X_train_scaled, synthetic_minority.drop('label', axis=1)], ignore_index=True)\n",
    "        y_train_ctgan = pd.concat([pd.Series(y_train).reset_index(drop=True), \n",
    "                                   synthetic_minority['label'].reset_index(drop=True)], \n",
    "                                  ignore_index=True)\n",
    "        \n",
    "        print(f\"After DP-CTGAN: {X_train_ctgan.shape}\")\n",
    "        print(f\"Class distribution after DP-CTGAN:\")\n",
    "        final_counts = y_train_ctgan.value_counts().sort_index()\n",
    "        print(final_counts)\n",
    "        \n",
    "        # Verify balance\n",
    "        if len(final_counts.unique()) == 1:\n",
    "            print(\"✅ Perfect balance achieved!\")\n",
    "        else:\n",
