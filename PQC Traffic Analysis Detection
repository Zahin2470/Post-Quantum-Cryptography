    "# ==================== Step 1: ANOVA Feature Selection ====================\n",
    "print(\"📊 Step 1: ANOVA Feature Selection\\n\")\n",
    "\n",
    "# Perform ANOVA F-test\n",
    "selector_anova = SelectKBest(f_classif, k='all')\n",
    "selector_anova.fit(X_train_smote, y_train_smote)\n",
    "\n",
    "# Get F-scores and p-values\n",
    "anova_scores = pd.DataFrame({\n",
    "    'Feature': X.columns,\n",
    "    'F_Score': selector_anova.scores_,\n",
    "    'P_Value': selector_anova.pvalues_\n",
    "})\n",
    "anova_scores = anova_scores.sort_values('F_Score', ascending=False)\n",
    "\n",
    "print(\"Top 15 features by ANOVA F-score:\")\n",
    "display(anova_scores.head(15))\n",
    "\n",
    "# Select top k features (e.g., top 50% or features with p < 0.05)\n",
    "k_anova = max(10, int(len(X.columns) * 0.5))  # At least 10 features\n",
    "top_anova_features = anova_scores.head(k_anova)['Feature'].tolist()\n",
    "\n",
    "print(f\"\\nSelected {len(top_anova_features)} features from ANOVA\")\n",
    "\n",
    "# Create filtered dataset\n",
    "X_train_anova = X_train_smote[top_anova_features]\n",
    "X_test_anova = X_test_scaled[top_anova_features]\n",
    "\n",
    "# ==================== Step 2: Genetic Algorithm Feature Selection ====================\n",
    "print(\"\\n🧬 Step 2: Genetic Algorithm Feature Selection\\n\")\n",
    "\n",
    "# Define fitness function for GA\n",
    "def evaluate_features(individual):\n",
    "    \"\"\"Fitness function: F1-score of Random Forest with selected features\"\"\"\n",
    "    # Convert binary individual to feature indices\n",
    "    selected_features = [i for i, bit in enumerate(individual) if bit == 1]\n",
    "    \n",
    "    # Need at least 1 feature\n",
    "    if len(selected_features) == 0:\n",
    "        return (0.0,)\n",
    "    \n",
    "    # Select features\n",
    "    X_selected = X_train_anova.iloc[:, selected_features]\n",
    "    \n",
    "    # Train a simple model\n",
    "    clf = RandomForestClassifier(n_estimators=50, max_depth=5, random_state=RANDOM_SEED, n_jobs=-1)\n",
    "    \n",
    "    # Cross-validation\n",
    "    cv_scores = cross_val_score(clf, X_selected, y_train_smote, cv=3, scoring='f1_weighted', n_jobs=-1)\n",
    "    \n",
    "    return (np.mean(cv_scores),)\n",
    "\n",
    "# Initialize DEAP for GA\n",
    "creator.create(\"FitnessMax\", base.Fitness, weights=(1.0,))\n",
    "creator.create(\"Individual\", list, fitness=creator.FitnessMax)\n",
    "\n",
    "toolbox = base.Toolbox()\n",
    "toolbox.register(\"attr_bool\", np.random.randint, 0, 2)\n",
    "toolbox.register(\"individual\", tools.initRepeat, creator.Individual, \n",
    "                 toolbox.attr_bool, n=len(top_anova_features))\n",
    "toolbox.register(\"population\", tools.initRepeat, list, toolbox.individual)\n",
    "toolbox.register(\"evaluate\", evaluate_features)\n",
    "toolbox.register(\"mate\", tools.cxTwoPoint)\n",
    "toolbox.register(\"mutate\", tools.mutFlipBit, indpb=0.05)\n",
    "toolbox.register(\"select\", tools.selTournament, tournsize=3)\n",
    "\n",
    "# Run GA\n",
    "print(\"Running Genetic Algorithm (this may take a few minutes)...\")\n",
    "population = toolbox.population(n=20)  # Small population for demo\n",
    "NGEN = 10  # Number of generations\n",
    "\n",
    "# Statistics\n",
    "stats = tools.Statistics(lambda ind: ind.fitness.values)\n",
    "stats.register(\"avg\", np.mean)\n",
    "stats.register(\"max\", np.max)\n",
    "\n",
    "# Evolution\n",
    "population, logbook = algorithms.eaSimple(population, toolbox, cxpb=0.7, mutpb=0.2, \n",
    "                                          ngen=NGEN, stats=stats, verbose=True)\n",
    "\n",
    "# Get best individual\n",
    "best_individual = tools.selBest(population, k=1)[0]\n",
    "ga_selected_indices = [i for i, bit in enumerate(best_individual) if bit == 1]\n",
    "ga_selected_features = [top_anova_features[i] for i in ga_selected_indices]\n",
    "\n",
    "print(f\"\\nGA selected {len(ga_selected_features)} features\")\n",
    "print(f\"Best fitness score: {best_individual.fitness.values[0]:.4f}\")\n",
    "\n",
    "# Create GA-filtered dataset\n",
    "X_train_ga = X_train_smote[ga_selected_features]\n",
    "X_test_ga = X_test_scaled[ga_selected_features]\n",
    "\n",
    "# ==================== Step 3: Mutual Information Ranking ====================\n",
    "print(\"\\n📈 Step 3: Mutual Information Ranking\\n\")\n",
    "\n",
    "# Calculate mutual information\n",
    "mi_scores = mutual_info_classif(X_train_ga, y_train_smote, random_state=RANDOM_SEED)\n",
    "mi_df = pd.DataFrame({\n",
    "    'Feature': ga_selected_features,\n",
    "    'MI_Score': mi_scores\n",
    "})\n",
    "mi_df = mi_df.sort_values('MI_Score', ascending=False)\n",
    "\n",
    "print(\"Mutual Information Scores:\")\n",
    "display(mi_df)\n",
    "\n",
    "# Select top features based on MI\n",
    "top_k_final = min(15, len(ga_selected_features))\n",
    "final_selected_features = mi_df.head(top_k_final)['Feature'].tolist()\n",
    "\n",
    "print(f\"\\n✅ Final {len(final_selected_features)} selected features:\")\n",
    "print(final_selected_features)\n",
    "\n",
    "# Create final dataset\n",
    "X_train_final = X_train_smote[final_selected_features]\n",
    "X_test_final = X_test_scaled[final_selected_features]\n",
    "\n",
    "# Visualize feature importance\n",
    "fig, axes = plt.subplots(1, 2, figsize=(15, 5))\n",
    "\n",
    "# ANOVA scores\n",
    "anova_scores.head(15).plot(x='Feature', y='F_Score', kind='barh', ax=axes[0], color='steelblue')\n",
    "axes[0].set_title('Top 15 Features - ANOVA F-Score')\n",
    "axes[0].set_xlabel('F-Score')\n",
    "\n",
    "# MI scores\n",
    "mi_df.plot(x='Feature', y='MI_Score', kind='barh', ax=axes[1], color='coral')\n",
    "axes[1].set_title('Final Features - Mutual Information')\n",
    "axes[1].set_xlabel('MI Score')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
